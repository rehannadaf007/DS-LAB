def linear_search(n, L1, target):
    
    for i in range (0,n):
        if L1[i] == target:
            return True
    return False
def binary_search(n, target):
    n.sort()
    low = 0
    high = len(n) - 1
    while low <= high:
        mid = (low + high) // 2
        if n[mid] == target:
            return True
        elif n[mid] < target:
            low = mid + 1
        else:
            high = mid - 1
    return False

